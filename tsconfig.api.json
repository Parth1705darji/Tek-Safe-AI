{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": "."
  },
  "include": [
    "api/**/*.ts",
    "src/lib/deepseek.ts",
    "src/lib/rag.ts",
    "src/types/index.ts"
  ]
}
