{
  "installCommand": "npm install --legacy-peer-deps",
  "rewrites": [
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "functions": {
    "api/chat.ts": { "maxDuration": 30 },
    "api/conversations.ts": { "maxDuration": 10 },
    "api/feedback.ts": { "maxDuration": 10 },
    "api/tools/[tool].ts": { "maxDuration": 15 },
    "api/webhooks/clerk.ts": { "maxDuration": 10 },
    "api/admin/stats.ts": { "maxDuration": 15 },
    "api/admin/kb.ts": { "maxDuration": 60 },
    "api/admin/users.ts": { "maxDuration": 10 },
    "api/admin/[resource].ts": { "maxDuration": 15 },
    "api/admin/user-actions.ts": { "maxDuration": 15 },
    "api/infrastructure/activation.ts": { "maxDuration": 10 }
  }
}
